// This is the Petrik Navigator database schema

generator client {
  provider      = "prisma-client"
  output        = "../generated/prisma"
  moduleFormat  = "cjs"
  binaryTargets = ["windows", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
}

model users {
  id            BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  email         String @unique
  password_hash String
}

model translations {
  lang_key String @db.VarChar(10)
  text_key String @db.VarChar(191)
  text     String @db.Text

  @@id([lang_key, text_key])
}

model buildings {
  id          BigInt       @id @default(autoincrement()) @db.UnsignedBigInt
  name        String       @unique @db.VarChar(191)
  description String       @db.Text
  x           Int          @db.SmallInt
  y           Int          @db.SmallInt
  classrooms  classrooms[]
  corridors   corridors[]
  lifts       lifts[]
  stairs      stairs[]
}

model classrooms {
  id              BigInt          @id @default(autoincrement()) @db.UnsignedBigInt
  name            String          @db.VarChar(255)
  capacity        Int             @db.UnsignedInt
  storey          Int             @db.TinyInt
  x               Int             @db.SmallInt
  y               Int             @db.SmallInt
  rotation        Int             @db.UnsignedSmallInt
  size_x          Int             @db.UnsignedInt
  size_y          Int             @db.UnsignedInt
  size_z          Int             @db.UnsignedInt
  description     String          @db.Text
  building_id     BigInt          @db.UnsignedBigInt
  type_id         BigInt          @db.UnsignedBigInt
  buildings       buildings       @relation(fields: [building_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  classroom_types classroom_types @relation(fields: [type_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([name, building_id])
}

model classroom_types {
  id         BigInt       @id @default(autoincrement()) @db.UnsignedBigInt
  name       String       @unique @db.VarChar(100)
  colorhex   String?      @db.VarChar(9)
  classrooms classrooms[]
}

model corridors {
  id           BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  name         String    @db.VarChar(255)
  storey       Int       @db.SmallInt
  x1           Int       @db.SmallInt
  y1           Int       @db.SmallInt
  x2           Int       @db.SmallInt
  y2           Int       @db.SmallInt
  width        Float     @db.Float
  barrier_free Boolean   @default(false)
  is_outdoor   Boolean   @default(false)
  building_id  BigInt    @db.UnsignedBigInt
  buildings    buildings @relation(fields: [building_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([name, building_id])
}

model lifts {
  id          BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  name        String    @db.VarChar(191)
  x           Int       @db.SmallInt
  y           Int       @db.SmallInt
  min_storey  Int       @db.SmallInt
  max_storey  Int       @db.SmallInt
  building_id BigInt    @db.UnsignedBigInt
  buildings   buildings @relation(fields: [building_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([name, building_id])
}

model stairs {
  id          BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  name        String    @db.VarChar(191)
  x           Int       @db.SmallInt
  y           Int       @db.SmallInt
  min_storey  Int       @db.SmallInt
  max_storey  Int       @db.SmallInt
  rotation    Int       @db.UnsignedSmallInt
  building_id BigInt    @db.UnsignedBigInt
  buildings   buildings @relation(fields: [building_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([name, building_id])
}
